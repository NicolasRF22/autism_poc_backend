# ============================================
# Configurações da Aplicação Autism.IA
# ============================================

# IMPORTANTE: Em produção, sempre usar DEBUG=False
DEBUG=False

# ============================================
# Configurações do Servidor Backend
# ============================================
# HOST: 0.0.0.0 permite conexões externas
HOST=0.0.0.0

# PORT: Porta onde o backend vai rodar
PORT=5000

# ============================================
# Google Gemini API (OBRIGATÓRIO)
# ============================================
# Obter sua chave em: https://aistudio.google.com/app/apikey
# É usada para o RAG Engine e geração de PEIs
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ============================================
# CORS (frontend autorizado)
# ============================================
# Em produção, informe o domínio do frontend.
# Para múltiplos domínios, separe por vírgula.
# Exemplo: https://app.seudominio.com,https://admin.seudominio.com
CORS_ALLOWED_ORIGINS=*

# ============================================
# Autenticação (JWT + RBAC)
# ============================================
# Usuário admin inicial (criado automaticamente se não houver admin)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Segredo para assinatura dos tokens JWT (trocar em produção)
AUTH_JWT_SECRET=CHANGE_ME_SUPER_SECRET_JWT

# Tempo de expiração do token (minutos)
AUTH_TOKEN_EXP_MINUTES=480

# ============================================
# ChromaDB (Vector Store)
# ============================================
# Modo 1 (local, padrão): use CHROMA_DB_PATH
CHROMA_DB_PATH=./backend/chroma_db
CHROMA_COLLECTION_NAME=documentos_pei

# Modo 2 (remoto via servidor HTTP Chroma):
# CHROMA_HOST=seu-host-chroma
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database
# CHROMA_AUTH_TOKEN=
# CHROMA_HEADERS_JSON={"x-api-key":"sua-chave"}

# ============================================
# Persistência de Dados da Aplicação
# ============================================
# Backend de dados:
# - file: usa JSON local (padrão atual)
# - postgres: usa PostgreSQL
# - dual: escreve em file + postgres (fase de migração)
DATA_BACKEND=file

# Obrigatório quando DATA_BACKEND=postgres ou dual
# Exemplo Render/Supabase:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database
DATABASE_URL=

# Observação:
# - ChromaDB continua sendo usado para embeddings (vector store)
# - PDFs e demais dados podem ser migrados em fases futuras para storage remoto

# ============================================
# Object Storage (PDFs / Anexos / PEIs)
# ============================================
# local: mantém arquivos no disco local (compatibilidade)
# supabase: usa Supabase Storage privado
OBJECT_STORAGE_BACKEND=local

# Obrigatório quando OBJECT_STORAGE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Buckets privados para documentos da aplicação
SUPABASE_STORAGE_BUCKET_RAG=rag-documents
SUPABASE_STORAGE_BUCKET_PEI=pei-documents
