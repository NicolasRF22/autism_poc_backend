# ============================================
# Configurações da Aplicação Autism.IA
# ============================================

# ⚠️ ATENÇÃO DEBUG:
# DEBUG=True  → Desenvolvimento (auto-reload, erros detalhados, INSEGURO)
# DEBUG=False → Produção (rápido, seguro, SEM stack traces)
# SEMPRE use False em produção!
DEBUG=True

# ============================================
# Configurações do Servidor
# ============================================
HOST=0.0.0.0
PORT=5000

# ============================================
# Google Gemini API (OBRIGATÓRIO)
# ============================================
# Obter em: https://aistudio.google.com/app/apikey
# Esta é a ÚNICA credencial necessária para a aplicação funcionar
GOOGLE_API_KEY=AIzaSyCsoDM8SfElMr-MxpTzrVtH_sMZaE5_ias

# ============================================
# Armazenamento
# ============================================
# A aplicação usa arquivos JSON para armazenar dados
# ChromaDB é usado apenas para o vector store (RAG)

# ============================================
# Autenticação (JWT + Admin)
# ============================================
# Importante: troque em produção
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=troque_esta_senha_forte
AUTH_JWT_SECRET=troque_este_segredo_jwt_forte
AUTH_TOKEN_EXP_MINUTES=480

# ============================================
# CORS (frontend autorizado)
# ============================================
# Em produção, defina o domínio do frontend
# Exemplo: CORS_ALLOWED_ORIGINS=https://app.seudominio.com
CORS_ALLOWED_ORIGINS=*

# ============================================
# ChromaDB (RAG)
# ============================================
# Modo local (padrão)
# CHROMA_DB_PATH=./backend/chroma_db
CHROMA_COLLECTION_NAME=documentos_pei

# Modo TryChroma Cloud
CHROMA_API_KEY=ck-8SnjRanqvtrwiWr6mFKqqSMnqoeQjU5SvxUPzTeutzmd
